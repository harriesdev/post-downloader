{
  "manifest_version": 3,
  "version": "1.0.6",
  "name": "Instagram Downloader",
  "description": "The Instagram Downloader lets you download Instagram content from public accounts — Video, Photos, Reels, Stories, and Highlights.",
  "icons": {
    "16": "static/icon/icon-16.png",
    "32": "static/icon/icon-32.png",
    "48": "static/icon/icon-48.png",
    "64": "static/icon/icon-64.png",
    "128": "static/icon/icon-128.png",
    "256": "static/icon/icon-256.png"
  },
  "action": {
    "default_title": "Instagram Downloader",
    "default_popup": "main.html",
    "default_icon": {
      "16": "static/icon/icon-16.png",
      "32": "static/icon/icon-32.png",
      "48": "static/icon/icon-48.png",
      "64": "static/icon/icon-64.png",
      "128": "static/icon/icon-128.png",
      "256": "static/icon/icon-256.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.instagram.com/*",
        "*://*.cdninstagram.com/*",
        "*://*.cdninstagram.net/*",
        "*://*.fbcdn.net/*"
      ],
      "js": [
        "static/js/webworker.js"
      ],
      "css": [
        "static/css/background.css"
      ]
    }
  ]
}